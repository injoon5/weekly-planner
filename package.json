{
  "name": "weekly-planner",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.check.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "preview": "vite preview",
    "start": "vite",
    "push:schema": "npx instant-cli@latest push schema --yes",
    "push:perms": "npx instant-cli@latest push perms --yes",
    "pull": "npx instant-cli@latest pull --yes"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@instantdb/admin": "^0.22.57",
    "@instantdb/react": "0.22.57",
    "@stylexjs/stylex": "0.19.0",
    "@tanstack/react-router": "1.170.17",
    "lucide-react": "^0.525.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylexjs/unplugin": "0.19.0",
    "@vitejs/plugin-react": "4.5.2",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "instant-cli": "0.22.57",
    "typescript": "^7.0.2",
    "vite": "6.3.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  }
}
