{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true
  },
  "include": [
    "src/command-result.js",
    "src/config.js",
    "src/drag.js",
    "src/event-packing.js",
    "src/grid-gesture.js",
    "src/grid-layout.js",
    "src/legacy.js",
    "src/links.js",
    "src/member-policy.js",
    "src/models.js",
    "src/prefs.js",
    "src/print-prefs.js",
    "src/roles.js",
    "src/share-access.js",
    "src/share-policy.js",
    "src/share.js",
    "src/theme-dom.js",
    "src/time.js",
    "src/transaction.js",
    "src/workspace-bootstrap.js"
  ]
}
