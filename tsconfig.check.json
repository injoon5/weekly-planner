{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true
  },
  "include": [
    "src/vite-env.d.ts",
    "src/board/legacy.js",
    "src/board/models.js",
    "src/board/prefs.js",
    "src/board/print-prefs.js",
    "src/board/workspace-bootstrap.js",
    "src/board/workspace-loading.js",
    "src/db/transaction.js",
    "src/grid/drag.js",
    "src/grid/event-packing.js",
    "src/grid/grid-gesture.js",
    "src/grid/grid-layout.js",
    "src/lib/command-result.js",
    "src/lib/config.js",
    "src/lib/links.js",
    "src/lib/time.js",
    "src/server/api-tokens.js",
    "src/server/rest.js",
    "src/sharing/member-policy.js",
    "src/sharing/roles.js",
    "src/sharing/share-access.js",
    "src/sharing/share-policy.js",
    "src/sharing/share.js",
    "src/theme/theme-dom.js"
  ]
}
