# Instant app id — set BOTH to the same value.
# Client (Vite) reads VITE_INSTANT_APP_ID; CLI + serverless read INSTANT_APP_ID.
INSTANT_APP_ID=
VITE_INSTANT_APP_ID=

# Admin token from https://www.instantdb.com/dash — required for `npm run push:*`
# and Vercel serverless functions `/api/invite` + `/api/share-meta` (set in
# Vercel project env for Preview and Production).
INSTANT_ADMIN_TOKEN=

# Optional pepper for REST API token hashing (SHA-256 of "pepper:token").
# Leave empty to keep legacy unpeppered hashes; set in production and keep
# stable — rotating it invalidates existing tokens until users re-create them
# (verify still accepts legacy hashes when this is set).
# API_TOKEN_PEPPER=

# CLI auth token from `npx instant-cli@latest login -p` — required for
# `npm run sync:auth-origins` (registers Vercel preview URLs with Instant).
# Add the same value as a GitHub Actions secret to keep origins in sync on main.
INSTANT_CLI_AUTH_TOKEN=

# Vercel project name in the Instant dashboard (defaults to repo slug: weekly-planner).
# VERCEL_PROJECT_NAME=weekly-planner

# Optional production/custom domain for the website auth origin.
# INSTANT_AUTH_WEBSITE_URL=your-domain.com

# Optional absolute site origin for Open Graph tags at build time
# (canonical, og:url, og:image → /api/og). On Vercel, production URL env is
# used automatically; set this for custom domains or non-Vercel builds.
# SITE_URL=https://your-domain.com
